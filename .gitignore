# Ignore compiled Python files
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/

# Ignore macOS system files
.DS_Store

# Ignore the root data/ folder entirely (legacy location)
# Package data is now in src/stellium/data/
/data/

# Ignore experimentation area
dev_experiments/

# Ignore the dist for now
dist/

# Ignore virtual environments
venv/
env/

# Ignore logs & temp files
*.log

# Ignore the caching system
.cache/

# Ignore coverage files
.coverage
coverage.json
htmlcov/

# Ignore development folder
dev/

# Sphinx docs output
docs/_build/

# Internal planning docs (transient; not tracked)
docs/planning/
docs/archive/

# Note: docs/development/ and docs/DOCS_INDEX.md are the tracked agent reference
# (linked from CLAUDE.md) and are intentionally NOT ignored.

# Test output artifacts (generated by doc codeblock tests and cookbook tests)
/*.svg
/*.pdf
/*.txt
examples/arc_directions/
examples/multicharts/

# Claude planning files
.claude/
claude_info/
# Untracked local rectification proving harness (superseded by src/stellium/rectification/)
docs/development/specs/rectification/harness/
docs/cookbooks/

# Build-time stats for the docs (see docs/conf.py _site_stats)
docs/_generated/

# Galleries: generated from the registries at build time (scripts/build_gallery_pages.py)
docs/THEME_GALLERY.md
docs/PALETTE_GALLERY.md
docs/gallery/

# Phase 0 inventory artifact (regenerate with scripts/i18n_surface.py)
i18n_surface.json

# Non-Latin font staging: binaries are distributed via GitHub Release (see
# scripts/build_font_manifest.py and docs/development/specs/FONTS_AND_CHART_I18N.md),
# not committed — they would bloat every clone. The meta.json + OFL license text stay.
assets/fonts/non-latin/**/*.ttf
assets/fonts/non-latin/**/*.otf
assets/fonts/non-latin/**/*.ttc

# Generated by scripts/build_font_manifest.py: the flat, upload-ready copies of the font
# packs. Uploaded to the GitHub Release, never committed.
font_upload/
